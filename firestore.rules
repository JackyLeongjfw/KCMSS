rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.englishName is string && data.englishName.size() <= 100
        && (data.className is string || !data.keys().hasAll(['className']))
        && (data.classNo is string || !data.keys().hasAll(['classNo']))
        && (data.total_score is number || !data.keys().hasAll(['total_score']))
        && (data.setupComplete is bool || !data.keys().hasAll(['setupComplete']));
    }

    // --- Collections ---

    // Users Collection
    match /users/{userId} {
      // Allow individual profile reads for any signed in user
      allow get: if isSignedIn();
      
      // Allow listing users, but force client to filter by setupComplete to avoid scraping incomplete data
      allow list: if isSignedIn() && (resource.data.setupComplete == true || userId == request.auth.uid);
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Allow updating common fields
        incoming().diff(existing()).affectedKeys().hasAny([
          'total_score', 'inventory', 'activeBadge', 'activeSkin', 
          'activeSuit', 'activeDecoration', 'setupComplete', 
          'englishName', 'className', 'classNo', 'missions', 
          'lastMissionUpdate', 'best_display', 'best_stars', 
          'best_sort_key', 'themeProgress', 'avatar'
        ])
      );

      // Analyses Subcollection
      match /analyses/{analysisId} {
        allow read, write: if isOwner(userId);
      }

      // Vocabulary Subcollection
      match /vocabulary/{vocabId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
