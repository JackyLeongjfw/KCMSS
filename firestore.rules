rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return (!data.keys().hasAll(['englishName']) || (data.englishName is string && data.englishName.size() <= 100))
        && (!data.keys().hasAll(['className']) || (data.className is string && data.className.size() <= 20))
        && (!data.keys().hasAll(['classNo']) || (data.classNo is string && data.classNo.size() <= 10))
        && (!data.keys().hasAll(['total_score']) || (data.total_score is number))
        && (!data.keys().hasAll(['setupComplete']) || (data.setupComplete is bool));
    }

    // --- Collections ---

    // Users Collection
    match /users/{userId} {
      // Allow individual profile reads (get and list) for any signed in user
      allow read: if isSignedIn();
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming());

      // Subcollections
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Battle Rooms Collection
    match /battle_rooms/{roomId} {
      // Allow any user to see rooms they are part of or waiting rooms
      allow read: if true;
      
      // Allow anyone to create a room (to support guest play)
      allow create: if true;
      
      // Allow updating a room if the user is one of the players
      allow update: if true;
    }
  }
}
