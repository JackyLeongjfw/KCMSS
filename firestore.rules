rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Admin check - include the user who set it up
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'a223402770@gmail.com' && request.auth.token.email_verified == true
      ); 
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['englishName', 'setupComplete'])
        && data.englishName is string && data.englishName.size() <= 100
        && data.setupComplete is bool
        && (data.get('xp', 0) is number)
        && (data.get('level', 1) is number)
        && (data.get('total_score', 0) is number);
    }

    match /users/{userId} {
      allow get: if true; // Public stats for leaderboards
      allow list: if true; 
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        // Allow updates to profile fields
        incoming().diff(existing()).affectedKeys().hasAny(['englishName', 'className', 'avatar', 'theme', 'xp', 'level', 'total_score', 'lastLogin', 'setupComplete'])
        // Ensure non-admins can't escalate privileges (if we had roles)
      );
    }

    // --- Battle Room Validation ---
    function isValidRoom(data) {
      return data.keys().hasAll(['status', 'playerUids', 'players', 'questions', 'createdAt'])
        && data.status in ['waiting', 'starting', 'active', 'finished']
        && data.playerUids is list && data.playerUids.size() <= 2
        && data.players is list && data.players.size() <= 2
        && data.questions is list && data.questions.size() == 10
        && data.createdAt is string; // Should be Server Timestamp but current code uses ISO string
    }

    function isPlayerInRoom(roomData) {
      return isSignedIn() && (request.auth.uid in roomData.playerUids);
    }

    match /battle_rooms/{roomId} {
      allow read: if true; // Publicly observable for joining
      
      allow create: if isSignedIn() && isValidRoom(incoming()) && incoming().playerUids.size() == 1;
      
      allow update: if (
        // Case 1: Joining a room
        (existing().status == 'waiting' && existing().playerUids.size() < 2 && incoming().playerUids.size() == 2) ||
        // Case 2: Player updating their progress or the room state
        (isPlayerInRoom(existing()) && (
          // Action: Mark as ready
          (incoming().diff(existing()).affectedKeys().hasOnly(['players', 'status'])) ||
          // Action: Answer question
          (incoming().diff(existing()).affectedKeys().hasOnly(['players', 'status', 'winnerId']))
        )) ||
        isAdmin()
      ) && isValidRoom(incoming());
      
      allow delete: if isAdmin();
    }
  }
}
