{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Student profile data including progress and inventory",
      "type": "object",
      "properties": {
        "englishName": { "type": "string" },
        "className": { "type": "string" },
        "classNo": { "type": "string" },
        "total_score": { "type": "integer" },
        "best_sort_key": { "type": "integer" },
        "best_display": { "type": "string" },
        "best_stars": { "type": "integer" },
        "avatar": { "type": "string" },
        "inventory": { "type": "array", "items": { "type": "string" } },
        "activeBadge": { "type": "string" },
        "setupComplete": { "type": "boolean" },
        "email": { "type": "string" },
        "themeProgress": { "type": "object" }
      },
      "required": ["englishName", "className", "classNo", "total_score"]
    },
    "VocabularyCard": {
      "title": "Personal Vocabulary Card",
      "description": "User saved vocabulary from AI or other sources",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "meaning": { "type": "string" },
        "partOfSpeech": { "type": "string" },
        "sentence": { "type": "string" },
        "theme": { "type": "string" },
        "section": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "EssayAnalysis": {
      "title": "Essay Analysis",
      "description": "Stored AI analysis of student essays",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "content": { "type": "string" },
        "translation": { "type": "string" },
        "vocabularySuggestion": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual student profiles"
    },
    "/users/{userId}/vocabulary/{vocabId}": {
      "schema": "VocabularyCard",
      "description": "Personal word bank"
    },
    "/essays/{essayId}": {
      "schema": "EssayAnalysis",
      "description": "History of essay analyses"
    }
  }
}
