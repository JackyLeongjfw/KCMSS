{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user progress, levels, and customization preferences.",
      "type": "object",
      "properties": {
        "englishName": { "type": "string" },
        "className": { "type": "string" },
        "avatar": { "type": "string" },
        "theme": { "type": "string" },
        "setupComplete": { "type": "boolean" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "total_score": { "type": "number" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["englishName", "setupComplete"]
    },
    "BattleRoom": {
      "title": "Battle Arena Room",
      "description": "Manages a live vocab duel between two players or a player and a bot.",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["waiting", "starting", "active", "finished"] },
        "playerUids": { "type": "array", "items": { "type": "string" } },
        "players": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uid": { "type": "string" },
              "name": { "type": "string" },
              "score": { "type": "number" },
              "progress": { "type": "number" },
              "ready": { "type": "boolean" },
              "finished": { "type": "boolean" }
            }
          }
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "word": { "type": "string" },
              "meaning": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "winnerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "playerUids", "players", "questions", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles accessible by the owner and readable for leaderboards."
    },
    "battle_rooms/{roomId}": {
      "schema": "BattleRoom",
      "description": "Rooms for vocabulary battles."
    }
  }
}
